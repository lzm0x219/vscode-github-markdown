{
  "name": "vscode-github-markdown",
  "displayName": "%displayName%",
  "version": "4.1.1",
  "description": "%description%",
  "categories": [
    "Other"
  ],
  "keywords": [
    "gfm",
    "github",
    "github markdown",
    "markdown",
    "markdown preview",
    "markdown style",
    "markdown theme",
    "readme",
    "visual studio code",
    "vscode"
  ],
  "homepage": "https://github.com/lzm0x219/vscode-github-markdown#readme",
  "bugs": {
    "url": "https://github.com/lzm0x219/vscode-github-markdown/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ZiMing Liu",
    "email": "lzm0x219@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lzm0x219/vscode-github-markdown.git"
  },
  "publisher": "lzm0x219",
  "sideEffects": false,
  "main": "dist/extension.js",
  "browser": "dist/extension.js",
  "scripts": {
    "build": "nub scripts/build/index.ts",
    "dev": "nub scripts/build/dev.ts",
    "update:emoji": "nub scripts/emoji/index.ts",
    "update:parity": "nub scripts/parity/index.ts refresh",
    "update:parity:offline": "nub scripts/parity/index.ts sync",
    "verify:parity": "nub scripts/parity/index.ts check",
    "verify:parity:remote": "nub scripts/parity/index.ts remote",
    "i18n-export": "nubx vscode-l10n-dev export --outDir ./l10n ./src",
    "test": "vitest run",
    "test:host:build": "nub run build && nubx tsdown --config tests/host/tsdown.config.ts",
    "test:host:desktop": "nub run test:host:build && nub scripts/host/desktop.ts",
    "test:host:web": "nub run test:host:build && nubx vscode-test-web --browser chromium --headless --quality stable --extensionDevelopmentPath=. --extensionTestsPath=.cache/host-tests/smoke.js --testRunnerDataDir=.cache/vscode-test-web",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "nubx vsce package",
    "release:note": "nub scripts/release/index.ts"
  },
  "devDependencies": {
    "@types/markdown-it": "14.1.2",
    "@types/node": "24.13.3",
    "@types/pngjs": "6.0.5",
    "@types/vscode": "1.74.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vscode/l10n-dev": "0.0.35",
    "@vscode/test-electron": "3.0.0",
    "@vscode/test-web": "0.0.81",
    "@vscode/vsce": "3.9.2",
    "generate-github-markdown-css": "6.6.0",
    "is-in-ci": "2.0.0",
    "lefthook": "2.1.10",
    "lightningcss": "1.32.0",
    "markdown-it": "14.3.0",
    "oxfmt": "0.59.0",
    "oxlint": "1.74.0",
    "oxlint-tsgolint": "0.24.0",
    "pixelmatch": "7.2.0",
    "playwright": "1.61.1",
    "pngjs": "7.0.0",
    "publint": "0.3.21",
    "rollup-plugin-visualizer": "7.0.1",
    "tsdown": "0.22.7",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "l10n": "./l10n",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewStyles": [
      "./dist/extension.preview.css"
    ],
    "commands": [
      {
        "command": "vscode-github-markdown.changeThemeMode",
        "title": "%command.changeThemeMode.title%"
      },
      {
        "command": "vscode-github-markdown.changeSingleTheme",
        "title": "%command.changeSingleTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeLightTheme",
        "title": "%command.changeLightTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeDarkTheme",
        "title": "%command.changeDarkTheme.title%"
      }
    ],
    "configuration": [
      {
        "title": "Markdown",
        "properties": {
          "githubMarkdown.theme.mode": {
            "order": 0,
            "type": "string",
            "description": "%configuration.theme.mode.description%",
            "enum": [
              "single",
              "system"
            ],
            "enumDescriptions": [
              "%configuration.theme.mode.single.enum.description%",
              "%configuration.theme.mode.system.enum.description%"
            ],
            "default": "system"
          },
          "githubMarkdown.theme.single": {
            "order": 1,
            "type": "string",
            "description": "%configuration.theme.single.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.light": {
            "order": 2,
            "type": "string",
            "description": "%configuration.theme.light.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.dark": {
            "order": 3,
            "type": "string",
            "description": "%configuration.theme.dark.description%",
            "default": "dark",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          }
        }
      },
      {
        "title": "Mermaid",
        "properties": {
          "githubMarkdown.mermaid.syncTheme": {
            "order": 0,
            "type": "boolean",
            "default": true,
            "description": "%configuration.mermaid.syncTheme.description%"
          }
        }
      },
      {
        "title": "Accessibility",
        "properties": {
          "githubMarkdown.accessibility.linkUnderlines": {
            "order": 0,
            "type": "boolean",
            "default": true,
            "description": "%configuration.accessibility.linkUnderlines.description%"
          }
        }
      }
    ]
  },
  "activationEvents": [],
  "icon": "assets/icon.png",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "packageManager": "pnpm@11.13.0+sha512.88d94724d8f2e6c186744a5584c6e59ecac869ec7ba15e9cb4cd628e8dc7066820b2481d8ee3b51ea8da323a7378068aa58c556a3720d32b7c20a051d088363a",
  "pricing": "Free"
}
