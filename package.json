{
  "name": "vscode-github-markdown",
  "displayName": "%displayName%",
  "version": "4.0.0",
  "description": "%description%",
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "github markdown",
    "markdown",
    "markdown style",
    "markdown theme"
  ],
  "homepage": "https://github.com/lzm0x219/vscode-github-markdown#readme",
  "bugs": {
    "url": "https://github.com/lzm0x219/vscode-github-markdown/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ZiMing Liu",
    "email": "lzm0x219@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lzm0x219/vscode-github-markdown.git"
  },
  "publisher": "lzm0x219",
  "main": "dist/extension.js",
  "browser": "dist/extension.js",
  "scripts": {
    "build": "bun scripts/build.ts",
    "dev": "bun scripts/dev.ts",
    "update:emoji": "bun scripts/update-github-emoji.ts",
    "i18n-export": "npx @vscode/l10n-dev export --outDir ./l10n ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "pnpm run i18n-export && pnpm run build && vsce package"
  },
  "devDependencies": {
    "@types/bun": "1.3.14",
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.3",
    "@types/vscode": "1.74.0",
    "@typescript/native-preview": "7.0.0-dev.20260618.1",
    "@vitest/coverage-v8": "^4.1.9",
    "@vscode/vsce": "3.9.2",
    "generate-github-markdown-css": "6.6.0",
    "lefthook": "2.1.9",
    "lightningcss": "1.32.0",
    "markdown-it": "14.2.0",
    "oxfmt": "0.55.0",
    "oxlint": "1.70.0",
    "oxlint-tsgolint": "0.23.0",
    "publint": "0.3.21",
    "tsdown": "0.22.3",
    "typescript": "6.0.3",
    "vitest": "4.1.9"
  },
  "l10n": "./l10n",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/extension.preview.js"
    ],
    "markdown.previewStyles": [
      "./dist/extension.preview.css"
    ],
    "commands": [
      {
        "command": "vscode-github-markdown.changeThemeMode",
        "title": "%command.changeThemeMode.title%"
      },
      {
        "command": "vscode-github-markdown.changeSingleTheme",
        "title": "%command.changeSingleTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeLightTheme",
        "title": "%command.changeLightTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeDarkTheme",
        "title": "%command.changeDarkTheme.title%"
      }
    ],
    "configuration": [
      {
        "title": "Markdown",
        "properties": {
          "githubMarkdown.theme.mode": {
            "order": 0,
            "type": "string",
            "description": "%configuration.theme.mode.description%",
            "enum": [
              "single",
              "system"
            ],
            "enumDescriptions": [
              "%configuration.theme.mode.single.enum.description%",
              "%configuration.theme.mode.system.enum.description%"
            ],
            "default": "system"
          },
          "githubMarkdown.theme.single": {
            "order": 1,
            "type": "string",
            "description": "%configuration.theme.single.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.light": {
            "order": 2,
            "type": "string",
            "description": "%configuration.theme.light.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.dark": {
            "order": 3,
            "type": "string",
            "description": "%configuration.theme.dark.description%",
            "default": "dark",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          }
        }
      },
      {
        "title": "Mermaid",
        "properties": {
          "githubMarkdown.mermaid.syncTheme": {
            "order": 0,
            "type": "boolean",
            "default": true,
            "description": "%configuration.mermaid.syncTheme.description%"
          }
        }
      }
    ]
  },
  "activationEvents": [],
  "icon": "assets/icon.png",
  "engines": {
    "node": ">=22",
    "vscode": "^1.74.0"
  },
  "packageManager": "pnpm@11.8.0+sha512.c1f5e7c4cb241c8f174b743851d82f42b802324afc8b0f116b96adb15aa06664948dde36960a3ba1079ba5b4b29dd0140135b94b5b5f5263592249d68e555f26",
  "pricing": "Free"
}
