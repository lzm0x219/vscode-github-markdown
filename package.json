{
  "name": "vscode-github-markdown",
  "displayName": "%displayName%",
  "version": "4.0.0",
  "description": "%description%",
  "categories": [
    "Other"
  ],
  "keywords": [
    "github",
    "github markdown",
    "markdown",
    "markdown style",
    "markdown theme"
  ],
  "homepage": "https://github.com/lzm0x219/vscode-github-markdown#readme",
  "bugs": {
    "url": "https://github.com/lzm0x219/vscode-github-markdown/issues"
  },
  "license": "MIT",
  "author": {
    "name": "ZiMing Liu",
    "email": "lzm0x219@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lzm0x219/vscode-github-markdown.git"
  },
  "publisher": "lzm0x219",
  "sideEffects": false,
  "main": "dist/extension.js",
  "browser": "dist/extension.js",
  "scripts": {
    "build": "nub scripts/build.ts",
    "dev": "nub scripts/dev.ts",
    "update:emoji": "nub scripts/update-github-emoji.ts",
    "i18n-export": "nubx vscode-l10n-dev export --outDir ./l10n ./src",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "package": "nubx vsce package",
    "release:note": "nub scripts/extract-release-notes.ts"
  },
  "devDependencies": {
    "@types/markdown-it": "14.1.2",
    "@types/node": "25.9.3",
    "@types/vscode": "1.74.0",
    "@typescript/native-preview": "7.0.0-dev.20260618.1",
    "@vitest/coverage-v8": "4.1.10",
    "@vscode/l10n-dev": "0.0.35",
    "@vscode/vsce": "3.9.2",
    "generate-github-markdown-css": "6.6.0",
    "is-in-ci": "2.0.0",
    "lefthook": "2.1.10",
    "lightningcss": "1.32.0",
    "markdown-it": "14.3.0",
    "oxfmt": "0.57.0",
    "oxlint": "1.72.0",
    "oxlint-tsgolint": "0.24.0",
    "publint": "0.3.21",
    "rollup-plugin-visualizer": "7.0.1",
    "tsdown": "0.22.3",
    "typescript": "7.0.2",
    "vitest": "4.1.10"
  },
  "l10n": "./l10n",
  "contributes": {
    "markdown.markdownItPlugins": true,
    "markdown.previewScripts": [
      "./dist/extension.preview.js"
    ],
    "markdown.previewStyles": [
      "./dist/extension.preview.css"
    ],
    "commands": [
      {
        "command": "vscode-github-markdown.changeThemeMode",
        "title": "%command.changeThemeMode.title%"
      },
      {
        "command": "vscode-github-markdown.changeSingleTheme",
        "title": "%command.changeSingleTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeLightTheme",
        "title": "%command.changeLightTheme.title%"
      },
      {
        "command": "vscode-github-markdown.changeDarkTheme",
        "title": "%command.changeDarkTheme.title%"
      }
    ],
    "configuration": [
      {
        "title": "Markdown",
        "properties": {
          "githubMarkdown.theme.mode": {
            "order": 0,
            "type": "string",
            "description": "%configuration.theme.mode.description%",
            "enum": [
              "single",
              "system"
            ],
            "enumDescriptions": [
              "%configuration.theme.mode.single.enum.description%",
              "%configuration.theme.mode.system.enum.description%"
            ],
            "default": "system"
          },
          "githubMarkdown.theme.single": {
            "order": 1,
            "type": "string",
            "description": "%configuration.theme.single.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.light": {
            "order": 2,
            "type": "string",
            "description": "%configuration.theme.light.description%",
            "default": "light",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          },
          "githubMarkdown.theme.dark": {
            "order": 3,
            "type": "string",
            "description": "%configuration.theme.dark.description%",
            "default": "dark",
            "enum": [
              "light",
              "light_colorblind",
              "light_high_contrast",
              "light_tritanopia",
              "dark",
              "dark_colorblind",
              "dark_dimmed",
              "dark_high_contrast",
              "dark_tritanopia"
            ],
            "enumDescriptions": [
              "%configuration.theme.light.enum.description%",
              "%configuration.theme.light_colorblind.enum.description%",
              "%configuration.theme.light_high_contrast.enum.description%",
              "%configuration.theme.light_tritanopia.enum.description%",
              "%configuration.theme.dark.enum.description%",
              "%configuration.theme.dark_colorblind.enum.description%",
              "%configuration.theme.dark_dimmed.enum.description%",
              "%configuration.theme.dark_high_contrast.enum.description%",
              "%configuration.theme.dark_tritanopia.enum.description%"
            ]
          }
        }
      },
      {
        "title": "Mermaid",
        "properties": {
          "githubMarkdown.mermaid.syncTheme": {
            "order": 0,
            "type": "boolean",
            "default": true,
            "description": "%configuration.mermaid.syncTheme.description%"
          }
        }
      }
    ]
  },
  "activationEvents": [],
  "icon": "assets/icon.png",
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "24.18.0",
      "onFail": "download"
    }
  },
  "engines": {
    "vscode": "^1.74.0"
  },
  "packageManager": "pnpm@11.11.0+sha512.4463f65fd80ed80d69bc1d4bf163ee94f605c7380fc318bb5b2ebe15f8cd12d49c51a4d59e951b401e764d3b6ca751cbf51bc50ed7001a6bcb4935e684c34882",
  "pricing": "Free"
}
